XRAY_BIN=/usr/local/bin/xray
TEST_URL=https://www.gstatic.com/generate_204
CURL_TIMEOUT=6
STARTUP_TIMEOUT=2.5
WORKERS=15
PORT_BASE=21080
KEY_LIST_LIMIT=200
EXTRA_KEY_LIST_LIMITS=100,50
TCP_PRECHECK=true
RATING_BASE_WEIGHT=0.55
RATING_RECENT_WEIGHT=0.30
RATING_LATENCY_WEIGHT=0.25
RATING_STREAK_BONUS_STEP=0.045
RATING_FAILURE_PENALTY_STEP=0.09
RATING_EXPERIENCE_BONUS_STEP=0.008
RATING_SLOW_PENALTY_MAX=0.2
